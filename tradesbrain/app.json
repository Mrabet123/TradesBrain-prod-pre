{
  "expo": {
    "name": "tradesbrain",
    "slug": "tradesbrain",
    "version": "1.0.0",
    "scheme": "tradesbrain",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "androidStatusBar": {
      "barStyle": "dark-content",
      "translucent": true
    },
    "androidNavigationBar": {
      "barStyle": "dark-content"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.tradesbrain",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "TradesBrain needs the microphone so you can describe jobs to Rex by voice."
      }
    },
    "android": {
      "package": "app.tradesbrain",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.app.tradesbrain"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.843071726886-637f7jngnqdi2gll7e5aoclbbp88bkca"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "TradesBrain needs the microphone so you can describe jobs to Rex by voice."
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "expo-sharing",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "f8792972-162a-4415-bd10-a1e3c92b5efa"
      }
    },
    "owner": "ghassenmans"
  }
}
